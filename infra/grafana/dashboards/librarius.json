{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Librarius — Vue d'ensemble",
  "uid": "librarius-overview",
  "tags": ["librarius"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requêtes HTTP (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (method, status)",
          "legendFormat": "{{method}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Mémoire JVM utilisée (octets)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes) by (area)",
          "legendFormat": "{{area}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Recherches catalogue (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(librarius_catalog_search_total) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latence HTTP p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, uri))",
          "legendFormat": "{{uri}}"
        }
      ]
    }
  ]
}
