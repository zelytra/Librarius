{
  "realm": "librarius",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "displayName": "Ma Bibliothèque",
  "roles": {
    "realm": [{ "name": "user", "description": "Utilisateur de Ma Bibliothèque" }]
  },
  "defaultRoles": ["user"],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@biblio.app",
      "firstName": "Alice",
      "lastName": "Lectrice",
      "credentials": [{ "type": "password", "value": "alice", "temporary": false }],
      "realmRoles": ["user"]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@biblio.app",
      "firstName": "Bob",
      "lastName": "Lecteur",
      "credentials": [{ "type": "password", "value": "bob", "temporary": false }],
      "realmRoles": ["user"]
    }
  ],
  "clients": [
    {
      "clientId": "librarius-web",
      "name": "Librarius PWA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:4173/*"],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
